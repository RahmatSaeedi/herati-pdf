@using PdfMerger.Client.Services
@using PdfMerger.Client.Models
@inject IAdvancedPdfService AdvancedPdfService
@inject ILocalizationService L

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            @if (!_isProcessing && string.IsNullOrEmpty(_resultMessage))
            {
                <MudText Typo="Typo.h6">@L.T("dialogs.pageNumbers.title")</MudText>

                @if (Files.Count > 1)
                {
                    <MudSelect @bind-Value="_selectedFile" Label="@L.T("dialogs.pageNumbers.selectPdfFile")" Variant="Variant.Outlined">
                        @foreach (var file in Files)
                        {
                            <MudSelectItem Value="@file">@file.Name (@file.PageCount @L.T("common.pages"))</MudSelectItem>
                        }
                    </MudSelect>
                }
                else if (Files.Count == 1)
                {
                    <MudAlert Severity="Severity.Info">
                        <strong>@L.T("common.file"):</strong> @Files[0].Name (@Files[0].PageCount @L.T("common.pages"))
                    </MudAlert>
                }

                <MudSelect @bind-Value="_position" Label="@L.T("dialogs.pageNumbers.position")" Variant="Variant.Outlined">
                    <MudSelectItem Value="@("bottom-center")">@L.T("conversionSettings.bottomCenter")</MudSelectItem>
                    <MudSelectItem Value="@("bottom-right")">@L.T("conversionSettings.bottomRight")</MudSelectItem>
                    <MudSelectItem Value="@("bottom-left")">@L.T("conversionSettings.bottomLeft")</MudSelectItem>
                    <MudSelectItem Value="@("top-center")">@L.T("conversionSettings.topCenter")</MudSelectItem>
                    <MudSelectItem Value="@("top-right")">@L.T("conversionSettings.topRight")</MudSelectItem>
                    <MudSelectItem Value="@("top-left")">@L.T("conversionSettings.topLeft")</MudSelectItem>
                </MudSelect>

                <MudSelect @bind-Value="_format" Label="@L.T("common.format")" Variant="Variant.Outlined">
                    <MudSelectItem Value="@("{page}")">@L.T("dialogs.pageNumbers.formatPageOnly")</MudSelectItem>
                    <MudSelectItem Value="@("Page {page}")">@L.T("dialogs.pageNumbers.formatPageN")</MudSelectItem>
                    <MudSelectItem Value="@("{page} of {total}")">@L.T("dialogs.pageNumbers.formatNOfTotal")</MudSelectItem>
                    <MudSelectItem Value="@("Page {page} of {total}")">@L.T("dialogs.pageNumbers.formatPageNOfTotal")</MudSelectItem>
                    <MudSelectItem Value="@("{page}/{total}")">@L.T("dialogs.pageNumbers.formatNSlashTotal")</MudSelectItem>
                </MudSelect>

                <MudNumericField @bind-Value="_fontSize"
                                 Label="@L.T("dialogs.pageNumbers.fontSize")"
                                 Variant="Variant.Outlined"
                                 Min="6"
                                 Max="24"
                                 Step="1" />

                <MudNumericField @bind-Value="_startPage"
                                 Label="@L.T("dialogs.pageNumbers.startPageNumber")"
                                 Variant="Variant.Outlined"
                                 Min="1"
                                 Max="@(_selectedFile?.PageCount ?? 1000)"
                                 Step="1"
                                 HelperText="@L.T("dialogs.pageNumbers.startPageHelp")" />

                <MudColorPicker @bind-Value="_textColor"
                                Label="@L.T("dialogs.pageNumbers.textColor")"
                                Variant="Variant.Outlined"
                                ColorPickerView="ColorPickerView.Palette" />

                <MudAlert Severity="Severity.Info" Dense="true">
                    <MudText Typo="Typo.caption">
                        @L.T("dialogs.pageNumbers.info") @L.T("common.preview"): @GetPreviewText()
                    </MudText>
                </MudAlert>

                <MudPaper Elevation="2" Class="pa-3" Style="background-color: #f5f5f5;">
                    <MudText Typo="Typo.body2" Align="Align.Center" Style="@($"font-size: {_fontSize}px;")">
                        @GetPreviewText()
                    </MudText>
                    <MudText Typo="Typo.caption" Align="Align.Center" Color="Color.Secondary">
                        @L.T("common.preview") (@L.T("dialogs.pageNumbers.position"): @_position)
                    </MudText>
                </MudPaper>
            }

            @if (_isProcessing)
            {
                <MudStack Spacing="2" AlignItems="AlignItems.Center">
                    <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
                    <MudText Typo="Typo.h6">@L.T("dialogs.pageNumbers.adding")</MudText>
                </MudStack>
            }

            @if (!string.IsNullOrEmpty(_resultMessage))
            {
                <MudAlert Severity="Severity.Success">
                    @_resultMessage
                </MudAlert>
            }

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error">
                    @_errorMessage
                </MudAlert>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">@(string.IsNullOrEmpty(_resultMessage) ? L.T("common.cancel") : L.T("common.close"))</MudButton>
        @if (string.IsNullOrEmpty(_resultMessage) && !_isProcessing)
        {
            <MudButton Color="Color.Primary"
                       Variant="Variant.Filled"
                       OnClick="AddPageNumbers"
                       Disabled="@(_selectedFile == null)">
                @L.T("dialogs.pageNumbers.addPageNumbers")
            </MudButton>
        }
        @if (!string.IsNullOrEmpty(_resultMessage))
        {
            <MudButton Color="Color.Secondary"
                       Variant="Variant.Outlined"
                       OnClick="StartNew">
                @L.T("dialogs.pageNumbers.processAnother")
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public List<FileItem> Files { get; set; } = new();

    private FileItem? _selectedFile;
    private string _position = "bottom-center";
    private string _format = "{page} of {total}";
    private int _fontSize = 10;
    private int _startPage = 1;
    private MudBlazor.Utilities.MudColor _textColor = new MudBlazor.Utilities.MudColor("#000000");
    private bool _isProcessing;
    private string _resultMessage = "";
    private string _errorMessage = "";

    protected override void OnInitialized()
    {
        _selectedFile = Files.FirstOrDefault();
    }

    private string GetPreviewText()
    {
        if (_selectedFile == null) return "1 of 10";

        var preview = _format
            .Replace("{page}", _startPage.ToString())
            .Replace("{total}", _selectedFile.PageCount.ToString());

        return preview;
    }

    private async Task AddPageNumbers()
    {
        if (_selectedFile == null) return;

        _isProcessing = true;
        _errorMessage = "";
        StateHasChanged();

        try
        {
            var options = new PageNumberOptions
            {
                FontSize = _fontSize,
                Position = _position,
                Format = _format,
                StartPage = _startPage,
                Color = "#000000" // Convert MudColor to hex if needed
            };

            var result = await AdvancedPdfService.AddPageNumbersAsync(_selectedFile.Data, options);

            if (result != null)
            {
                MudDialog.Close(DialogResult.Ok(result));
            }
            else
            {
                _errorMessage = L.T("dialogs.pageNumbers.failed");
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
            Console.WriteLine($"Page numbers error: {ex}");
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }

    private void StartNew()
    {
        _resultMessage = "";
        _errorMessage = "";
        StateHasChanged();
    }

    private void Close() => MudDialog.Cancel();

    [Inject] private ISnackbar Snackbar { get; set; } = null!;
}
