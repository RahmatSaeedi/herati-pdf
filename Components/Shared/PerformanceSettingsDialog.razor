@using PdfMerger.Client.Services
@inject IWebWorkerService WebWorkerService
@inject ISnackbar Snackbar
@inject ILocalizationService L

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText Typo="Typo.h6">@L.T("dialogs.performance.title")</MudText>

            <MudPaper Elevation="1" Class="pa-4">
                <MudStack Spacing="2">
                    <div class="d-flex justify-space-between align-center">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.subtitle1" Style="font-weight: 500;">
                                <MudIcon Icon="@Icons.Material.Filled.Speed" Size="Size.Small" Class="mr-1" />
                                @L.T("dialogs.performance.webWorkers")
                            </MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                @L.T("dialogs.performance.webWorkersDescription")
                            </MudText>
                        </MudStack>
                        <MudSwitch @bind-Value="_webWorkersEnabled"
                                   @bind-Value:after="OnWebWorkersToggled"
                                   Color="Color.Primary"
                                   Disabled="@(!WebWorkerService.IsSupported)" />
                    </div>

                    @if (!WebWorkerService.IsSupported)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true">
                            @L.T("dialogs.performance.notSupported")
                        </MudAlert>
                    }
                    else if (_webWorkersEnabled && WebWorkerService.IsInitialized)
                    {
                        <MudAlert Severity="Severity.Success" Dense="true">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" />
                                <span>@L.T("dialogs.performance.active")</span>
                            </MudStack>
                        </MudAlert>
                    }
                </MudStack>
            </MudPaper>

            <MudText Typo="Typo.subtitle2" Style="font-weight: 500;">@L.T("dialogs.performance.benefits")</MudText>
            <MudStack Spacing="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Speed" Color="Color.Success" Size="Size.Small" />
                    <MudText Typo="Typo.body2">@L.T("dialogs.performance.benefit1")</MudText>
                </MudStack>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.TouchApp" Color="Color.Success" Size="Size.Small" />
                    <MudText Typo="Typo.body2">@L.T("dialogs.performance.benefit2")</MudText>
                </MudStack>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Memory" Color="Color.Success" Size="Size.Small" />
                    <MudText Typo="Typo.body2">@L.T("dialogs.performance.benefit3")</MudText>
                </MudStack>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.ViewInAr" Color="Color.Success" Size="Size.Small" />
                    <MudText Typo="Typo.body2">@L.T("dialogs.performance.benefit4")</MudText>
                </MudStack>
            </MudStack>

            <MudDivider />

            <MudText Typo="Typo.subtitle2" Style="font-weight: 500;">@L.T("dialogs.performance.recommended")</MudText>
            <MudAlert Severity="Severity.Info" Dense="true">
                @L.T("dialogs.performance.recommendedInfo")
            </MudAlert>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Color="Color.Primary">@L.T("common.close")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    private bool _webWorkersEnabled = true;

    protected override async Task OnInitializedAsync()
    {
        // Check if Web Workers are supported and initialized
        _webWorkersEnabled = WebWorkerService.IsSupported;

        if (_webWorkersEnabled && !WebWorkerService.IsInitialized)
        {
            try
            {
                await WebWorkerService.InitializeAsync();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error initializing Web Worker: {ex.Message}");
                _webWorkersEnabled = false;
            }
        }
    }

    private async Task OnWebWorkersToggled()
    {
        if (_webWorkersEnabled && !WebWorkerService.IsInitialized)
        {
            try
            {
                var success = await WebWorkerService.InitializeAsync();
                if (success)
                {
                    Snackbar.Add(L.T("dialogs.performance.enabled"), Severity.Success);
                }
                else
                {
                    _webWorkersEnabled = false;
                    Snackbar.Add(L.T("dialogs.performance.failedToInitialize"), Severity.Error);
                }
            }
            catch (Exception ex)
            {
                _webWorkersEnabled = false;
                Snackbar.Add($"{L.T("common.error")}: {ex.Message}", Severity.Error);
            }
        }
        else if (!_webWorkersEnabled)
        {
            Snackbar.Add(L.T("dialogs.performance.disabled"), Severity.Info);
        }

        StateHasChanged();
    }

    private void Close()
    {
        MudDialog.Close(DialogResult.Ok(_webWorkersEnabled));
    }
}
