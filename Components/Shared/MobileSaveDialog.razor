@using Microsoft.JSInterop
@using PdfMerger.Client.Services
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar
@inject ILocalizationService L
@implements IAsyncDisposable

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Class="mr-1" Color="Color.Success" />
            @L.T("dialogs.mobileSave.pdfReady")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3" AlignItems="AlignItems.Center" Class="pa-2">

            <MudText Typo="Typo.body1" Align="Align.Center">
                @L.T("dialogs.mobileSave.chooseHow")
            </MudText>

            <!-- PDF Preview/Info -->
            <MudPaper Elevation="2" Style="padding: 16px; border-radius: 8px; width: 100%; background: linear-gradient(135deg, #f5f5f5 0%, #e3f2fd 100%);">
                <MudStack Spacing="2" AlignItems="AlignItems.Center">
                    @if (!string.IsNullOrEmpty(DataUrl))
                    {
                        <MudPaper Elevation="3" Style="padding: 4px; background: white; border-radius: 4px;">
                            <embed src="@DataUrl" type="application/pdf" width="200" height="150" style="border-radius: 4px;" />
                        </MudPaper>
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.PictureAsPdf"
                                 Color="Color.Error"
                                 Style="font-size: 64px;" />
                    }
                    <MudStack Spacing="0" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.body2" Style="font-weight: 600;" Align="Align.Center">
                            @FileName
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @FormatFileSize(FileSize)
                        </MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Style="width: 100%;">
                    @_errorMessage
                </MudAlert>
            }

            <MudStack Spacing="2" Style="width: 100%; margin-top: 16px;">
                @if (_supportsWebShare)
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Large"
                               FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Share"
                               OnClick="ShareFile"
                               Disabled="_isProcessing">
                        @if (_isProcessing && _currentAction == "share")
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>@L.T("dialogs.mobileSave.sharing")</span>
                        }
                        else
                        {
                            <span>@L.T("dialogs.mobileSave.shareOrSave")</span>
                        }
                    </MudButton>
                }

                <MudButton Variant="@(_supportsWebShare ? Variant.Outlined : Variant.Filled)"
                           Color="Color.Primary"
                           Size="Size.Large"
                           FullWidth="true"
                           StartIcon="@Icons.Material.Filled.Download"
                           OnClick="DownloadFile"
                           Disabled="_isProcessing">
                    @if (_isProcessing && _currentAction == "download")
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>@(_isIOS ? L.T("dialogs.mobileSave.opening") : L.T("dialogs.mobileSave.downloading"))</span>
                    }
                    else
                    {
                        <span>@(_isIOS ? L.T("dialogs.mobileSave.openInSafari") : L.T("dialogs.mobileSave.downloadToDevice"))</span>
                    }
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Secondary"
                           Size="Size.Large"
                           FullWidth="true"
                           StartIcon="@Icons.Material.Filled.OpenInNew"
                           OnClick="PreviewFile"
                           Disabled="_isProcessing">
                    @if (_isProcessing && _currentAction == "preview")
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>@L.T("dialogs.mobileSave.opening")</span>
                    }
                    else
                    {
                        <span>@L.T("dialogs.mobileSave.previewInNewTab")</span>
                    }
                </MudButton>
            </MudStack>

            @if (_isIOS)
            {
                <MudText Typo="Typo.caption" Align="Align.Center" Color="Color.Secondary" Style="margin-top: 8px;">
                    💡 @L.T("dialogs.mobileSave.iosTip")
                </MudText>
            }
            else
            {
                <MudText Typo="Typo.caption" Align="Align.Center" Color="Color.Secondary" Style="margin-top: 8px;">
                    💡 @L.T("dialogs.mobileSave.tip")
                </MudText>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Color="Color.Default">@L.T("common.close")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public string FileName { get; set; } = "document.pdf";

    [Parameter]
    public long FileSize { get; set; }

    [Parameter]
    public string? DataUrl { get; set; }

    private bool _supportsWebShare;
    private bool _isProcessing;
    private string _currentAction = "";
    private string? _errorMessage;
    private IJSObjectReference? _pdfModule;
    private bool _isIOS;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Console.WriteLine($"MobileSaveDialog initialized - File: {FileName}, Size: {FileSize}, HasDataUrl: {!string.IsNullOrEmpty(DataUrl)}");

            _pdfModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/pdfInterop.js");

            // Check if this is iOS
            _isIOS = await _pdfModule.InvokeAsync<bool>("isIOSDevice");
            Console.WriteLine($"iOS device: {_isIOS}");

            // Check if Web Share API is supported
            _supportsWebShare = await JSRuntime.InvokeAsync<bool>("eval",
                "navigator.share !== undefined");

            Console.WriteLine($"Web Share API supported: {_supportsWebShare}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error initializing mobile save dialog: {ex.Message}");
            _errorMessage = L.T("dialogs.mobileSave.featuresNotAvailable");
            _supportsWebShare = false;
            _isIOS = false;
        }

        StateHasChanged();
    }

    private async Task ShareFile()
    {
        if (_pdfModule == null) return;

        _isProcessing = true;
        _currentAction = "share";
        _errorMessage = null;
        StateHasChanged();

        try
        {
            await _pdfModule.InvokeVoidAsync("shareFile");
            Snackbar.Add(L.T("dialogs.mobileSave.sharedSuccessfully"), Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error sharing file: {ex.Message}");
            _errorMessage = L.T("dialogs.mobileSave.couldntShare");
            Snackbar.Add(L.T("dialogs.mobileSave.shareCancelled"), Severity.Info);
        }
        finally
        {
            _isProcessing = false;
            _currentAction = "";
            StateHasChanged();
        }
    }

    private async Task DownloadFile()
    {
        if (_pdfModule == null) return;

        _isProcessing = true;
        _currentAction = "download";
        _errorMessage = null;
        StateHasChanged();

        try
        {
            await _pdfModule.InvokeVoidAsync("downloadFileMobile");

            if (_isIOS)
            {
                Snackbar.Add(L.T("dialogs.mobileSave.openedInSafari"), Severity.Success, config =>
                {
                    config.VisibleStateDuration = 4000;
                });
            }
            else
            {
                Snackbar.Add(L.T("dialogs.mobileSave.downloadStarted"), Severity.Success);
            }

            // Don't close the dialog immediately, give user time to see the message
            await Task.Delay(2000);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error downloading file: {ex.Message}");

            if (_isIOS)
            {
                _errorMessage = L.T("dialogs.mobileSave.couldntOpenPdf");
                Snackbar.Add(ex.Message.Contains("popup") ? L.T("dialogs.mobileSave.allowPopups") : $"{L.T("common.error")}: {ex.Message}", Severity.Warning);
            }
            else
            {
                _errorMessage = L.T("dialogs.mobileSave.downloadFailed");
                Snackbar.Add($"{L.T("dialogs.mobileSave.downloadError")}: {ex.Message}", Severity.Error);
            }
        }
        finally
        {
            _isProcessing = false;
            _currentAction = "";
            StateHasChanged();
        }
    }

    private async Task PreviewFile()
    {
        if (_pdfModule == null) return;

        _isProcessing = true;
        _currentAction = "preview";
        _errorMessage = null;
        StateHasChanged();

        try
        {
            await _pdfModule.InvokeVoidAsync("openPdfPreview");
            Snackbar.Add(L.T("dialogs.mobileSave.openedInNewTab"), Severity.Success);

            // Don't close the dialog immediately
            await Task.Delay(1000);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error previewing file: {ex.Message}");
            _errorMessage = L.T("dialogs.mobileSave.couldntOpenPreview");
            Snackbar.Add($"{L.T("dialogs.mobileSave.previewError")}: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isProcessing = false;
            _currentAction = "";
            StateHasChanged();
        }
    }

    private void Close()
    {
        MudDialog.Cancel();
    }

    private string FormatFileSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }

    public async ValueTask DisposeAsync()
    {
        if (_pdfModule != null)
        {
            try
            {
                await _pdfModule.DisposeAsync();
            }
            catch { }
        }
    }
}
