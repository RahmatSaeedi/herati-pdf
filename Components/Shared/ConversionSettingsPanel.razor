@using PdfMerger.Client.Models
@using PdfMerger.Client.Services
@inject ILocalizationService L

<MudPaper Elevation="2" Class="pa-4" Style="border-radius: 8px;">
    <MudStack Spacing="3">
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Small" Class="mr-2" />
            @L.T("conversionSettings.title")
        </MudText>

        <MudDivider />

        @* Page Size *@
        <MudStack Spacing="1">
            <MudText Typo="Typo.subtitle2">@L.T("conversionSettings.pageSize")</MudText>
            <MudSelect T="PageSize" @bind-Value="Settings.PageSize" Variant="Variant.Outlined" Margin="Margin.Dense">
                <MudSelectItem Value="PageSize.A4">@L.T("pageSizes.a4")</MudSelectItem>
                <MudSelectItem Value="PageSize.A3">@L.T("pageSizes.a3")</MudSelectItem>
                <MudSelectItem Value="PageSize.A5">@L.T("pageSizes.a5")</MudSelectItem>
                <MudSelectItem Value="PageSize.Letter">@L.T("pageSizes.letter")</MudSelectItem>
                <MudSelectItem Value="PageSize.Legal">@L.T("pageSizes.legal")</MudSelectItem>
                <MudSelectItem Value="PageSize.Tabloid">@L.T("pageSizes.tabloid")</MudSelectItem>
            </MudSelect>
        </MudStack>

        @* Orientation *@
        <MudStack Spacing="1">
            <MudText Typo="Typo.subtitle2">@L.T("conversionSettings.orientation")</MudText>
            <MudRadioGroup T="PageOrientation" @bind-Value="Settings.Orientation">
                <MudRadio T="PageOrientation" Value="PageOrientation.Portrait" Color="Color.Primary">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.Portrait" Size="Size.Small" />
                        <MudText>@L.T("conversionSettings.portrait")</MudText>
                    </MudStack>
                </MudRadio>
                <MudRadio T="PageOrientation" Value="PageOrientation.Landscape" Color="Color.Primary">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.Landscape" Size="Size.Small" />
                        <MudText>@L.T("conversionSettings.landscape")</MudText>
                    </MudStack>
                </MudRadio>
            </MudRadioGroup>
        </MudStack>

        @* Normalize Page Sizes *@
        <MudSwitch @bind-Value="Settings.NormalizePageSizes"
                   Color="Color.Primary"
                   Label="@L.T("conversionSettings.normalizePageSizes")"
                   Class="mt-2">
            <MudTooltip Text="@L.T("conversionSettings.normalizeTooltip")">
                <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="ml-1" />
            </MudTooltip>
        </MudSwitch>

        @* Margins *@
        <MudExpansionPanels>
            <MudExpansionPanel Text="@($"{L.T("conversionSettings.margins")} ({L.T("conversionSettings.marginsHelp")})")">
                <MudGrid Spacing="2">
                    <MudItem xs="6">
                        <MudNumericField @bind-Value="Settings.Margins.Top"
                                         Label="@L.T("conversionSettings.top")"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         Min="0"
                                         Max="144"
                                         Step="6" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudNumericField @bind-Value="Settings.Margins.Bottom"
                                         Label="@L.T("conversionSettings.bottom")"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         Min="0"
                                         Max="144"
                                         Step="6" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudNumericField @bind-Value="Settings.Margins.Left"
                                         Label="@L.T("conversionSettings.left")"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         Min="0"
                                         Max="144"
                                         Step="6" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudNumericField @bind-Value="Settings.Margins.Right"
                                         Label="@L.T("conversionSettings.right")"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         Min="0"
                                         Max="144"
                                         Step="6" />
                    </MudItem>
                </MudGrid>
            </MudExpansionPanel>
        </MudExpansionPanels>

        @* Page Numbering *@
        <MudStack Spacing="1">
            <MudSwitch @bind-Value="Settings.AddPageNumbers" Color="Color.Primary" Label="@L.T("conversionSettings.addPageNumbers")" />

            @if (Settings.AddPageNumbers)
            {
                <MudStack Spacing="2" Class="ml-8">
                    <MudSelect T="PageNumberPosition" @bind-Value="Settings.NumberPosition" Label="@L.T("conversionSettings.numberPosition")" Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem Value="PageNumberPosition.TopLeft">@L.T("conversionSettings.topLeft")</MudSelectItem>
                        <MudSelectItem Value="PageNumberPosition.TopCenter">@L.T("conversionSettings.topCenter")</MudSelectItem>
                        <MudSelectItem Value="PageNumberPosition.TopRight">@L.T("conversionSettings.topRight")</MudSelectItem>
                        <MudSelectItem Value="PageNumberPosition.BottomLeft">@L.T("conversionSettings.bottomLeft")</MudSelectItem>
                        <MudSelectItem Value="PageNumberPosition.BottomCenter">@L.T("conversionSettings.bottomCenter")</MudSelectItem>
                        <MudSelectItem Value="PageNumberPosition.BottomRight">@L.T("conversionSettings.bottomRight")</MudSelectItem>
                    </MudSelect>

                    <MudTextField @bind-Value="Settings.NumberFormat"
                                  Label="@L.T("conversionSettings.numberFormat")"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  HelperText="@L.T("conversionSettings.numberFormatHelp")" />
                </MudStack>
            }
        </MudStack>

        @* Export Format *@
        <MudStack Spacing="1">
            <MudText Typo="Typo.subtitle2">@L.T("conversionSettings.exportFormat")</MudText>
            <MudRadioGroup T="ExportFormat" @bind-Value="Settings.Format">
                <MudRadio T="ExportFormat" Value="ExportFormat.PDF" Color="Color.Primary">@L.T("conversionSettings.pdfStandard")</MudRadio>
                <MudRadio T="ExportFormat" Value="ExportFormat.PDFA" Color="Color.Primary">@L.T("conversionSettings.pdfArchival")</MudRadio>
            </MudRadioGroup>
        </MudStack>

        @* Compression *@
        <MudStack Spacing="1">
            <MudText Typo="Typo.subtitle2">@L.T("conversionSettings.compressionLevel")</MudText>
            <MudSlider @bind-Value="CompressionValue" Min="0" Max="3" Step="1" Color="Color.Primary">
                <MudText>@GetCompressionLabel()</MudText>
            </MudSlider>
        </MudStack>

        @* Image Quality *@
        <MudStack Spacing="1">
            <MudText Typo="Typo.subtitle2">@L.T("conversionSettings.imageQuality"): @Settings.ImageQuality%</MudText>
            <MudSlider @bind-Value="Settings.ImageQuality" Min="50" Max="100" Step="5" Color="Color.Info" />
        </MudStack>

        @* Image Options *@
        <MudSwitch @bind-Value="Settings.CompressImages" Color="Color.Primary" Label="@L.T("conversionSettings.compressImages")" />
        <MudSwitch @bind-Value="Settings.AutoRotateFromExif" Color="Color.Primary" Label="@L.T("conversionSettings.autoRotateExif")" />

        @* Reset Button *@
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Secondary"
                   StartIcon="@Icons.Material.Filled.RestartAlt"
                   OnClick="ResetToDefaults"
                   FullWidth="true">
            @L.T("conversionSettings.resetToDefaults")
        </MudButton>
    </MudStack>
</MudPaper>

@code {
    [Parameter]
    public PdfConversionOptions Settings { get; set; } = new();

    [Parameter]
    public EventCallback<PdfConversionOptions> SettingsChanged { get; set; }

    private int CompressionValue
    {
        get => Settings.Compression switch
        {
            CompressionLevel.None => 0,
            CompressionLevel.Low => 1,
            CompressionLevel.Medium => 2,
            CompressionLevel.High => 3,
            _ => 2
        };
        set
        {
            Settings.Compression = value switch
            {
                0 => CompressionLevel.None,
                1 => CompressionLevel.Low,
                2 => CompressionLevel.Medium,
                3 => CompressionLevel.High,
                _ => CompressionLevel.Medium
            };
        }
    }

    private string GetCompressionLabel()
    {
        return Settings.Compression switch
        {
            CompressionLevel.None => L.T("common.none"),
            CompressionLevel.Low => L.T("common.low"),
            CompressionLevel.Medium => L.T("common.medium"),
            CompressionLevel.High => L.T("common.high"),
            _ => L.T("common.medium")
        };
    }

    private async Task ResetToDefaults()
    {
        Settings.PageSize = PageSize.A4;
        Settings.Orientation = PageOrientation.Portrait;
        Settings.NormalizePageSizes = true;
        Settings.Margins = new Margins { Top = 72, Right = 72, Bottom = 72, Left = 72 };
        Settings.AddPageNumbers = false;
        Settings.NumberPosition = PageNumberPosition.BottomCenter;
        Settings.NumberFormat = "Page {0}";
        Settings.ImageQuality = 85;
        Settings.CompressImages = true;
        Settings.AutoRotateFromExif = false;
        Settings.Compression = CompressionLevel.Medium;
        Settings.Format = ExportFormat.PDF;

        await SettingsChanged.InvokeAsync(Settings);
    }
}
