@using PdfMerger.Client.Services
@using PdfMerger.Client.Models
@inject IAdvancedPdfService AdvancedPdfService
@inject ILocalizationService L

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            @if (!_isProcessing && string.IsNullOrEmpty(_generatedCodeUrl))
            {
                <MudText Typo="Typo.h6">@L.T("dialogs.qrBarcode.title")</MudText>

                @if (Files.Count > 1)
                {
                    <MudSelect @bind-Value="_selectedFile" Label="@L.T("dialogs.qrBarcode.selectPdfFile", "Select PDF File")" Variant="Variant.Outlined">
                        @foreach (var file in Files)
                        {
                            <MudSelectItem Value="@file">@file.Name</MudSelectItem>
                        }
                    </MudSelect>
                }
                else if (Files.Count == 1)
                {
                    <MudAlert Severity="Severity.Info">
                        <strong>@L.T("common.file"):</strong> @Files[0].Name
                    </MudAlert>
                }

                <MudRadioGroup @bind-Value="_codeType">
                    <MudRadio T="string" Value="@("qr")" Color="Color.Primary">@L.T("dialogs.qrBarcode.qrCode")</MudRadio>
                    <MudRadio T="string" Value="@("barcode")" Color="Color.Primary">@L.T("dialogs.qrBarcode.barcode")</MudRadio>
                </MudRadioGroup>

                <MudTextField @bind-Value="_contentText"
                              Label="@L.T("dialogs.qrBarcode.enterContent")"
                              Variant="Variant.Outlined"
                              Lines="3"
                              MaxLength="@(_codeType == "qr" ? 2000 : 100)"
                              HelperText="@(_codeType == "qr" ? L.T("dialogs.qrBarcode.qrHelperText", "URL, text, contact info, etc.") : L.T("dialogs.qrBarcode.barcodeHelperText", "Numbers or text for barcode"))"
                              Required="true" />

                @if (_codeType == "barcode")
                {
                    <MudSelect @bind-Value="_barcodeFormat" Label="@L.T("dialogs.qrBarcode.barcodeFormat")" Variant="Variant.Outlined">
                        <MudSelectItem Value="@("CODE128")">CODE128 (@L.T("dialogs.qrBarcode.generalPurpose", "General purpose"))</MudSelectItem>
                        <MudSelectItem Value="@("EAN13")">EAN-13 (@L.T("dialogs.qrBarcode.products", "Products"))</MudSelectItem>
                        <MudSelectItem Value="@("UPC")">UPC (@L.T("dialogs.qrBarcode.products", "Products"))</MudSelectItem>
                        <MudSelectItem Value="@("CODE39")">CODE39 (@L.T("dialogs.qrBarcode.alphanumeric", "Alphanumeric"))</MudSelectItem>
                        <MudSelectItem Value="@("ITF14")">ITF-14 (@L.T("dialogs.qrBarcode.shipping", "Shipping"))</MudSelectItem>
                    </MudSelect>
                }

                <MudNumericField @bind-Value="_pageNumber" Label="@L.T("common.page")" Variant="Variant.Outlined" Min="0" HelperText="@L.T("dialogs.signature.pageNumberHelp", "0 = first page, 1 = second page, etc.")" />

                <MudStack Row="true" Spacing="2">
                    <MudNumericField @bind-Value="_xPosition" Label="@L.T("dialogs.signature.xPosition", "X Position")" Variant="Variant.Outlined" Min="0" Max="600" Step="10" />
                    <MudNumericField @bind-Value="_yPosition" Label="@L.T("dialogs.signature.yPosition", "Y Position")" Variant="Variant.Outlined" Min="0" Max="800" Step="10" />
                </MudStack>

                <MudStack Row="true" Spacing="2">
                    <MudNumericField @bind-Value="_codeWidth" Label="@L.T("dialogs.signature.width")" Variant="Variant.Outlined" Min="50" Max="400" Step="10" />
                    <MudNumericField @bind-Value="_codeHeight" Label="@L.T("dialogs.signature.height")" Variant="Variant.Outlined" Min="50" Max="400" Step="10" />
                </MudStack>

                <MudAlert Severity="Severity.Info" Dense="true">
                    <MudText Typo="Typo.caption">
                        @(_codeType == "qr" ? L.T("dialogs.qrBarcode.qrInfo", "QR codes can store URLs, text, contact info, WiFi credentials, and more.") :
                          L.T("dialogs.qrBarcode.barcodeInfo", "Barcodes are ideal for product codes, inventory tracking, and shipping labels."))
                    </MudText>
                </MudAlert>

                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="GeneratePreview" FullWidth="true">
                    @L.T("common.preview") @(_codeType == "qr" ? L.T("dialogs.qrBarcode.qrCode") : L.T("dialogs.qrBarcode.barcode"))
                </MudButton>
            }

            @if (_isProcessing)
            {
                <MudStack Spacing="2" AlignItems="AlignItems.Center">
                    <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
                    <MudText Typo="Typo.h6">@_statusMessage</MudText>
                </MudStack>
            }

            @if (!string.IsNullOrEmpty(_generatedCodeUrl))
            {
                <MudStack Spacing="2">
                    <MudText Typo="Typo.h6">@L.T("dialogs.qrBarcode.generated") @(_codeType == "qr" ? L.T("dialogs.qrBarcode.qrCode") : L.T("dialogs.qrBarcode.barcode"))</MudText>

                    <MudPaper Elevation="2" Class="pa-4 d-flex justify-center">
                        <img src="@_generatedCodeUrl" alt="@L.T("dialogs.qrBarcode.generatedCode")" style="max-width: 100%; max-height: 300px;" />
                    </MudPaper>

                    <MudAlert Severity="Severity.Success">
                        <MudText Typo="Typo.body2">
                            <strong>@L.T("dialogs.qrBarcode.content"):</strong> @_contentText
                        </MudText>
                    </MudAlert>

                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @L.T("common.page"): @_pageNumber | @L.T("dialogs.qrBarcode.position"): (@_xPosition, @_yPosition) | @L.T("dialogs.qrBarcode.size"): @_codeWidth x @_codeHeight px
                    </MudText>
                </MudStack>
            }

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error">
                    @_errorMessage
                </MudAlert>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">@(string.IsNullOrEmpty(_generatedCodeUrl) ? L.T("common.cancel") : L.T("common.close"))</MudButton>
        @if (string.IsNullOrEmpty(_generatedCodeUrl) && !_isProcessing)
        {
            <MudButton Color="Color.Primary"
                       Variant="Variant.Filled"
                       OnClick="AddCodeToPdf"
                       Disabled="@(string.IsNullOrEmpty(_contentText) || _selectedFile == null)">
                @L.T("dialogs.qrBarcode.addToPdf")
            </MudButton>
        }
        @if (!string.IsNullOrEmpty(_generatedCodeUrl))
        {
            <MudButton Color="Color.Secondary"
                       Variant="Variant.Outlined"
                       OnClick="StartNew">
                @L.T("dialogs.qrBarcode.generateAnother")
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public List<FileItem> Files { get; set; } = new();

    private FileItem? _selectedFile;
    private string _codeType = "qr"; // qr or barcode
    private string _contentText = "";
    private string _barcodeFormat = "CODE128";
    private bool _isProcessing;
    private string _statusMessage = "";
    private string _generatedCodeUrl = "";
    private string _errorMessage = "";

    // Position and size defaults
    private int _pageNumber = 0;
    private int _xPosition = 400;
    private int _yPosition = 700;
    private int _codeWidth = 120;
    private int _codeHeight = 120;

    protected override void OnInitialized()
    {
        _selectedFile = Files.FirstOrDefault();
    }

    private async Task GeneratePreview()
    {
        if (string.IsNullOrWhiteSpace(_contentText))
        {
            _errorMessage = L.T("dialogs.qrBarcode.enterContentError");
            return;
        }

        _isProcessing = true;
        _statusMessage = L.T("dialogs.qrBarcode.generating", _codeType == "qr" ? L.T("dialogs.qrBarcode.qrCode") : L.T("dialogs.qrBarcode.barcode"));
        _errorMessage = "";
        StateHasChanged();

        try
        {
            if (_codeType == "qr")
            {
                var options = new QRCodeOptions
                {
                    Width = _codeWidth,
                    DarkColor = "#000000",
                    LightColor = "#ffffff"
                };

                _generatedCodeUrl = await AdvancedPdfService.GenerateQRCodeAsync(_contentText, options) ?? "";
            }
            else
            {
                var options = new BarcodeOptions
                {
                    Width = 2,
                    Height = _codeHeight,
                    DisplayValue = true,
                    FontSize = 12
                };

                _generatedCodeUrl = await AdvancedPdfService.GenerateBarcodeAsync(_contentText, _barcodeFormat, options) ?? "";
            }

            if (string.IsNullOrEmpty(_generatedCodeUrl))
            {
                _errorMessage = L.T("dialogs.qrBarcode.failedToGenerate", _codeType == "qr" ? L.T("dialogs.qrBarcode.qrCode") : L.T("dialogs.qrBarcode.barcode"));
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
            Console.WriteLine($"Code generation error: {ex}");
        }
        finally
        {
            _isProcessing = false;
            _statusMessage = "";
            StateHasChanged();
        }
    }

    private async Task AddCodeToPdf()
    {
        if (_selectedFile == null || string.IsNullOrWhiteSpace(_contentText)) return;

        _isProcessing = true;
        _statusMessage = L.T("dialogs.qrBarcode.addingToPdf");
        _errorMessage = "";
        StateHasChanged();

        try
        {
            byte[]? result = null;

            if (_codeType == "qr")
            {
                var options = new QRCodeOptions
                {
                    Width = _codeWidth,
                    DarkColor = "#000000",
                    LightColor = "#ffffff"
                };

                result = await AdvancedPdfService.AddQRCodeToPdfAsync(
                    _selectedFile.Data,
                    _contentText,
                    pageNumber: _pageNumber,
                    _xPosition,
                    _yPosition,
                    _codeWidth,
                    options);
            }
            else
            {
                var options = new BarcodeOptions
                {
                    Width = 2,
                    Height = _codeHeight,
                    DisplayValue = true,
                    FontSize = 12
                };

                result = await AdvancedPdfService.AddBarcodeToPdfAsync(
                    _selectedFile.Data,
                    _contentText,
                    _barcodeFormat,
                    pageNumber: _pageNumber,
                    _xPosition,
                    _yPosition,
                    _codeWidth,
                    _codeHeight,
                    options);
            }

            if (result != null)
            {
                MudDialog.Close(DialogResult.Ok(result));
            }
            else
            {
                _errorMessage = L.T("dialogs.qrBarcode.failedToAdd");
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
            Console.WriteLine($"Add code to PDF error: {ex}");
        }
        finally
        {
            _isProcessing = false;
            _statusMessage = "";
            StateHasChanged();
        }
    }

    private void StartNew()
    {
        _generatedCodeUrl = "";
        _errorMessage = "";
        _contentText = "";
        StateHasChanged();
    }

    private void Close() => MudDialog.Cancel();

    [Inject] private ISnackbar Snackbar { get; set; } = null!;
}
