@using PdfMerger.Client.Services
@inject IJSRuntime JSRuntime
@inject ILocalizationService L

<MudDialog>
    <DialogContent>
        <MudContainer MaxWidth="MaxWidth.Large" Style="max-height: 70vh; overflow-y: auto;">
            <MudStack Spacing="3">
                <MudText Typo="Typo.h4" Align="Align.Center" Style="font-weight: 600;">
                    <MudIcon Icon="@Icons.Material.Filled.Help" Class="mr-2" />
                    @L.T("help.title")
                </MudText>

                <MudAlert Severity="Severity.Info" Dense="true">
                    @L.T("help.privacyNotice")
                </MudAlert>

                <!-- Quick Start -->
                <MudPaper Elevation="2" Class="pa-4">
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.h6" Style="font-weight: 600;">
                            <MudIcon Icon="@Icons.Material.Filled.Bolt" Color="Color.Primary" Class="mr-1" />
                            @L.T("help.quickStart.title")
                        </MudText>
                        <MudText Typo="Typo.body2">
                            1. @L.T("help.quickStart.step1")<br/>
                            2. @L.T("help.quickStart.step2")<br/>
                            3. @L.T("help.quickStart.step3")<br/>
                            4. @L.T("help.quickStart.step4")
                        </MudText>
                    </MudStack>
                </MudPaper>

                <!-- Core Features -->
                <MudText Typo="Typo.h6" Style="font-weight: 600;">@L.T("help.coreFeatures")</MudText>

                <MudExpansionPanels MultiExpansion="true">
                    <!-- Merge PDFs -->
                    <MudExpansionPanel Text="@L.T("help.mergePdfs.title")">
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.body2">
                                @L.T("help.mergePdfs.description")
                            </MudText>
                            <MudAlert Severity="Severity.Success" Dense="true">
                                @L.T("help.mergePdfs.tip")
                            </MudAlert>
                        </MudStack>
                    </MudExpansionPanel>

                    <!-- Convert to PDF -->
                    <MudExpansionPanel Text="@L.T("help.convert.title")">
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.body2">
                                @L.T("help.convert.supportedFormats")<br/><br/>
                                @L.T("help.convert.settings")
                            </MudText>
                        </MudStack>
                    </MudExpansionPanel>

                    <!-- Compress PDF -->
                    <MudExpansionPanel Text="@L.T("help.compress.title")">
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.body2">
                                @L.T("help.compress.levels")
                            </MudText>
                        </MudStack>
                    </MudExpansionPanel>

                    <!-- Digital Signatures -->
                    <MudExpansionPanel Text="@L.T("help.signatures.title")">
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.body2">
                                @L.T("help.signatures.methods")
                            </MudText>
                        </MudStack>
                    </MudExpansionPanel>

                    <!-- OCR Text Extraction -->
                    <MudExpansionPanel Text="@L.T("help.ocr.title")">
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.body2">
                                @L.T("help.ocr.description")<br/><br/>
                                @L.T("help.ocr.tip")
                            </MudText>
                        </MudStack>
                    </MudExpansionPanel>

                    <!-- QR & Barcode -->
                    <MudExpansionPanel Text="@L.T("help.qrBarcode.title")">
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.body2">
                                @L.T("help.qrBarcode.qr")<br/><br/>
                                @L.T("help.qrBarcode.barcode")
                            </MudText>
                        </MudStack>
                    </MudExpansionPanel>

                    <!-- Watermarks & Page Numbers -->
                    <MudExpansionPanel Text="@L.T("help.watermarks.title")">
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.body2">
                                @L.T("help.watermarks.watermark")<br/><br/>
                                @L.T("help.watermarks.pageNumbers")
                            </MudText>
                        </MudStack>
                    </MudExpansionPanel>

                    <!-- Password Protection -->
                    <MudExpansionPanel Text="@L.T("help.passwordProtection.title")">
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.body2">
                                @L.T("help.passwordProtection.description")
                            </MudText>
                        </MudStack>
                    </MudExpansionPanel>

                    <!-- Batch Operations -->
                    <MudExpansionPanel Text="@L.T("help.batchOperations.title")">
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.body2">
                                @L.T("help.batchOperations.description")
                            </MudText>
                        </MudStack>
                    </MudExpansionPanel>

                    <!-- Templates -->
                    <MudExpansionPanel Text="@L.T("help.templates.title")">
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.body2">
                                @L.T("help.templates.description")
                            </MudText>
                        </MudStack>
                    </MudExpansionPanel>

                    <!-- Camera Scanner -->
                    <MudExpansionPanel Text="@L.T("help.cameraScanner.title")">
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.body2">
                                @L.T("help.cameraScanner.description")<br/><br/>
                                @L.T("help.cameraScanner.tip")
                            </MudText>
                        </MudStack>
                    </MudExpansionPanel>
                </MudExpansionPanels>

                <!-- Advanced Features -->
                <MudText Typo="Typo.h6" Style="font-weight: 600; margin-top: 16px;">@L.T("help.advancedFeatures")</MudText>

                <MudPaper Elevation="2" Class="pa-4">
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.body2">
                            @L.T("help.webWorkers")<br/><br/>
                            @L.T("help.keyboardShortcuts")<br/><br/>
                            @L.T("help.touchGestures")<br/><br/>
                            @L.T("help.offlineMode")<br/><br/>
                            @L.T("help.recentFilesHelp")
                        </MudText>
                    </MudStack>
                </MudPaper>

                <!-- Privacy & Security -->
                <MudPaper Elevation="2" Class="pa-4" Style="background-color: var(--mud-palette-success-lighten); margin-top: 16px;">
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.h6" Style="font-weight: 600;">
                            <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Success" Class="mr-1" />
                            @L.T("help.privacySecurity.title")
                        </MudText>
                        <MudText Typo="Typo.body2">
                            ✓ @L.T("help.privacySecurity.clientSide")<br/>
                            ✓ @L.T("help.privacySecurity.noUploads")<br/>
                            ✓ @L.T("help.privacySecurity.noStorage")<br/>
                            ✓ @L.T("help.privacySecurity.noTracking")<br/>
                            ✓ @L.T("help.privacySecurity.openSource")<br/>
                            ✓ @L.T("help.privacySecurity.worksOffline")
                        </MudText>
                    </MudStack>
                </MudPaper>

                <!-- Support & Feedback -->
                <MudPaper Elevation="2" Class="pa-4" Style="margin-top: 16px;">
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.h6" Style="font-weight: 600;">
                            <MudIcon Icon="@Icons.Material.Filled.Favorite" Color="Color.Error" Class="mr-1" />
                            @L.T("help.support.title")
                        </MudText>
                        <MudText Typo="Typo.body2">
                            @L.T("help.support.description")
                        </MudText>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Warning"
                                   StartIcon="@Icons.Material.Filled.Coffee"
                                   Href="https://buymeacoffee.com/rahmatsaeedi"
                                   Target="_blank"
                                   Style="max-width: 300px;">
                            @L.T("help.support.buyMeCoffee") ☕
                        </MudButton>
                    </MudStack>
                </MudPaper>
            </MudStack>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Color="Color.Primary" Variant="Variant.Filled">@L.T("common.gotIt")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    private void Close()
    {
        MudDialog.Close(DialogResult.Ok(true));
    }
}
