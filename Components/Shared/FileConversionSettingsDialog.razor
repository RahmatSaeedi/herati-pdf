@using PdfMerger.Client.Models
@using PdfMerger.Client.Services
@inject ILocalizationService L

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText Typo="Typo.h6">@L.T("fileSettings.title", FileName)</MudText>

            <MudDivider />

            @* Toggle: Use Global Settings vs Custom Settings *@
            <MudSwitch @bind-Value="_useCustomSettings" Color="Color.Primary" Label="@L.T("fileSettings.useCustomSettings")" />

            @if (!_useCustomSettings)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Filled">
                    @L.T("fileSettings.useGlobalInfo")
                </MudAlert>
            }
            else
            {
                <MudPaper Elevation="1" Class="pa-4">
                    <MudStack Spacing="3">
                        @* Page Size *@
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.subtitle2">@L.T("fileSettings.pageSize")</MudText>
                            <MudSelect T="PageSize" @bind-Value="_settings.PageSize" Variant="Variant.Outlined" Margin="Margin.Dense">
                                <MudSelectItem Value="PageSize.A4">@L.T("pageSizes.a4")</MudSelectItem>
                                <MudSelectItem Value="PageSize.A3">@L.T("pageSizes.a3")</MudSelectItem>
                                <MudSelectItem Value="PageSize.A5">@L.T("pageSizes.a5")</MudSelectItem>
                                <MudSelectItem Value="PageSize.Letter">@L.T("pageSizes.letter")</MudSelectItem>
                                <MudSelectItem Value="PageSize.Legal">@L.T("pageSizes.legal")</MudSelectItem>
                                <MudSelectItem Value="PageSize.Tabloid">@L.T("pageSizes.tabloid")</MudSelectItem>
                            </MudSelect>
                        </MudStack>

                        @* Orientation *@
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.subtitle2">@L.T("fileSettings.orientation")</MudText>
                            <MudRadioGroup T="PageOrientation" @bind-Value="_settings.Orientation">
                                <MudRadio T="PageOrientation" Value="PageOrientation.Portrait" Color="Color.Primary">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Filled.Portrait" Size="Size.Small" />
                                        <MudText>@L.T("fileSettings.portrait")</MudText>
                                    </MudStack>
                                </MudRadio>
                                <MudRadio T="PageOrientation" Value="PageOrientation.Landscape" Color="Color.Primary">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Filled.Landscape" Size="Size.Small" />
                                        <MudText>@L.T("fileSettings.landscape")</MudText>
                                    </MudStack>
                                </MudRadio>
                            </MudRadioGroup>
                        </MudStack>

                        @* Image Crop Mode *@
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.subtitle2">@L.T("fileSettings.imageFitting")</MudText>
                            <MudSelect T="ImageCropMode" @bind-Value="_settings.CropMode" Variant="Variant.Outlined" Margin="Margin.Dense">
                                <MudSelectItem Value="ImageCropMode.None">@L.T("fileSettings.none")</MudSelectItem>
                                <MudSelectItem Value="ImageCropMode.Fit">@L.T("fileSettings.fit")</MudSelectItem>
                                <MudSelectItem Value="ImageCropMode.Fill">@L.T("fileSettings.fill")</MudSelectItem>
                                <MudSelectItem Value="ImageCropMode.Stretch">@L.T("fileSettings.stretch")</MudSelectItem>
                            </MudSelect>
                        </MudStack>

                        @* Image Quality *@
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.subtitle2">@L.T("fileSettings.imageQuality"): @_settings.ImageQuality%</MudText>
                            <MudSlider @bind-Value="_settings.ImageQuality" Min="50" Max="100" Step="5" Color="Color.Info" />
                        </MudStack>

                        @* Image Options *@
                        <MudSwitch @bind-Value="_settings.CompressImages" Color="Color.Primary" Label="@L.T("fileSettings.compressImages")" />
                        <MudSwitch @bind-Value="_settings.AutoRotateFromExif" Color="Color.Primary" Label="@L.T("fileSettings.autoRotateExif")" />
                    </MudStack>
                </MudPaper>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@L.T("common.cancel")</MudButton>
        @if (_useCustomSettings)
        {
            <MudButton Color="Color.Secondary" OnClick="ClearCustomSettings">@L.T("fileSettings.useGlobalSettings")</MudButton>
        }
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">@L.T("common.apply")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public string FileName { get; set; } = string.Empty;

    [Parameter]
    public PdfConversionOptions Settings { get; set; } = new();

    private PdfConversionOptions _settings = new();
    private bool _useCustomSettings;

    protected override void OnInitialized()
    {
        // Make a copy of the settings to avoid modifying the original until Apply is clicked
        _settings = new PdfConversionOptions
        {
            PageSize = Settings.PageSize,
            Orientation = Settings.Orientation,
            Margins = new Margins
            {
                Top = Settings.Margins.Top,
                Right = Settings.Margins.Right,
                Bottom = Settings.Margins.Bottom,
                Left = Settings.Margins.Left
            },
            AddPageNumbers = Settings.AddPageNumbers,
            NumberPosition = Settings.NumberPosition,
            NumberFormat = Settings.NumberFormat,
            ImageQuality = Settings.ImageQuality,
            CompressImages = Settings.CompressImages,
            AutoRotateFromExif = Settings.AutoRotateFromExif,
            CropMode = Settings.CropMode,
            Compression = Settings.Compression,
            Format = Settings.Format
        };

        // Determine if custom settings are being used (checking if Settings parameter was provided with non-default values)
        _useCustomSettings = Settings.PageSize != PageSize.A4 ||
                            Settings.Orientation != PageOrientation.Portrait ||
                            Settings.ImageQuality != 85 ||
                            Settings.CropMode != ImageCropMode.None;
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private void ClearCustomSettings()
    {
        _useCustomSettings = false;
    }

    private void Submit()
    {
        if (_useCustomSettings)
        {
            MudDialog.Close(DialogResult.Ok(new { Settings = _settings }));
        }
        else
        {
            // Return null to indicate no custom settings (use global)
            MudDialog.Close(DialogResult.Ok(new { Settings = (PdfConversionOptions?)null }));
        }
    }
}
